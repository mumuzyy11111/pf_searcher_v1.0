# Local secrets
.env
*.env
!*.env.example
config/app.env

# Python caches and virtual environments
__pycache__/
*.py[cod]
.venv/
venv/

# Logs
*.log

# Non-runtime local/assets
assets/raw/
assets/misc/
*.spec
eval/

# Build and packaging output
build/
dist/

# Generated search indexes
data/chroma_db/
data/bm25_index/
data/aon_source_spell_cache.json
data/local_chm_only_sources.json
data/player_companion_aon_supplements.json

# Raw CHM/source dumps and extractor-only inputs
*.chm
*.chw

# Scratch scripts are not stable entry points
scripts/_scratch/*
!scripts/_scratch/README.md

# Keep only runtime-facing docs in the GitHub build
docs/*
!docs/API_KEY_CONFIGURATION.md
!docs/CHARACTER_SCHEMA_ZH.md
!docs/CODEBASE_ORGANIZATION.md
!docs/CODE_OVERVIEW_ZH.md
!docs/README_RAG.md
!docs/更新文档.md

# Generated viewer bundle; exceeds GitHub's regular file size limit
result/Pathfinder-v2.14-SC-viewer.html
result/Pathfinder-v2.14-SC-viewer-embedded.html

# Large/intermediate page cache and extraction reports
result/*.json
result/index/
result/pages/
result/**/*.md
result/**/*.tsv
result/**/*.csv
result/**/*report*.json
result/**/*check*.json
result/**/*qa.json
result/**/*unparsed.json
result/*/spells-*-*.json
!result/*/spells-*-model.json
result/feats/*
!result/feats/
!result/feats/feats-frontend.json
result/classes/*
!result/classes/
!result/classes/classes-extracted.json
result/items/*
!result/items/
!result/items/wondrous-items.json
